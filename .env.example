# Decision Intelligence local example
# Copy this file to `.env.local` for local frontend + ML API development.
# Do not place provider secrets in browser env. Configure them in Supabase Edge Function secrets.

# Frontend
VITE_ENV=development
VITE_SUPABASE_URL=https://decision-intelligence-dev.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.dev-anon-key
VITE_ML_API_URL=http://127.0.0.1:8000

# Model routing shown to the frontend and used by local helpers
VITE_DI_GEMINI_MODEL=gemini-3.1-pro-preview
VITE_DI_DEEPSEEK_MODEL=deepseek-chat
VITE_DI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Product flags
VITE_DI_RISK_AWARE=false
VITE_DI_PROACTIVE_ALERTS=true

# Browser-side observability
# VITE_SENTRY_DSN=https://PUBLIC_KEY@o000.ingest.sentry.io/0000000
# VITE_AGENT_LOG_ENDPOINT=http://127.0.0.1:7242/ingest/00000000-0000-0000-0000-000000000000

# Local ML API / worker
DI_ENV=development
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DI_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Execution guardrails
DI_MAX_ROWS_PER_SHEET=2000000
DI_MAX_SKUS=5000
DI_SOLVER_MAX_SECONDS=90
DI_BOM_MAX_EDGES=200000
DI_BOM_MAX_DEPTH=12
DI_FORECAST_MAX_SERIES=5000
DI_FORECAST_TIMEOUT_SECONDS=90
DI_BOM_TIMEOUT_SECONDS=90
DI_JOB_MAX_ATTEMPTS=3
DI_WORKER_POLL_SECONDS=2
DI_HEARTBEAT_INTERVAL_SECONDS=5

# Solver runtime
DI_SOLVER_ENGINE=ortools
DI_CHRONOS_ENABLED=false

# ERP integration
USE_MOCK_ERP=true
ERP_ENDPOINT=https://erp.company.internal/api/v1
ERP_API_KEY=dev-erp-api-key

# Ralph Loop (autonomous agent loop for digital workers)
VITE_RALPH_LOOP_ENABLED=false
VITE_RALPH_MAX_ITERATIONS=30
VITE_RALPH_MAX_COST=5.00
VITE_RALPH_LLM_MODEL=anthropic/claude-sonnet-4.5

# Server-side only examples
# Set these with `supabase secrets set ...`, not in the browser environment:
# FRONTEND_ORIGIN=https://decision-intelligence-web.example.com
# GEMINI_API_KEY=dev-gemini-key
# DEEPSEEK_API_KEY=dev-deepseek-key
# SUPABASE_SERVICE_ROLE_KEY=dev-service-role-key
