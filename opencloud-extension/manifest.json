{
  "id": "web-app-decision-intelligence",
  "name": "Decision Intelligence",
  "version": "1.0.0",
  "description": "AI-powered supply chain decision intelligence embedded in OpenCloud.",
  "entrypoint": "index.html",
  "config": {
    "di_api_url": {
      "type": "string",
      "display_name": "DI API URL",
      "description": "URL of the Decision Intelligence FastAPI backend",
      "default": "http://localhost:8000"
    },
    "supabase_url": {
      "type": "string",
      "display_name": "Supabase URL",
      "description": "URL of the Supabase instance",
      "default": ""
    },
    "auto_import": {
      "type": "boolean",
      "display_name": "Auto-import files",
      "description": "Automatically import selected files into DI pipeline",
      "default": false
    }
  },
  "permissions": [
    "files:read",
    "files:write",
    "sharing:read",
    "sharing:write",
    "notifications:create"
  ],
  "extensions": {
    "file_actions": [
      {
        "name": "Analyze with DI",
        "icon": "brain",
        "file_types": [".xlsx", ".csv", ".json", ".xls"],
        "handler": "analyzeFile"
      },
      {
        "name": "Run Forecast",
        "icon": "trending-up",
        "file_types": [".xlsx", ".csv"],
        "handler": "runForecast"
      }
    ],
    "sidebar_panel": {
      "name": "Decision Intelligence",
      "icon": "bar-chart-2",
      "component": "SidebarPanel"
    }
  }
}
