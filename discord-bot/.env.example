# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# Comma-separated channel IDs that the bot will respond in (leave empty to allow all)
DISCORD_ALLOWED_CHANNELS=

# Project root (defaults to parent directory)
# DI_PROJECT_ROOT=/Users/xuweijin/Decision-Intelligence-

# Claude CLI path (auto-detected, override if needed)
# CLAUDE_CLI_PATH=/path/to/claude

# Claude response timeout in ms (default 120000 = 2 min)
# CLAUDE_TIMEOUT=120000

# Per-user rate limit in seconds (default 5)
# RATE_LIMIT_SECONDS=5
