# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Provider API
# Provider keys are configured in Supabase Edge Function secrets (server-side), not in frontend env.
# Example:
# supabase secrets set GEMINI_API_KEY=your_gemini_api_key
# supabase secrets set DI_GEMINI_AGENT_TRANSPORT=hybrid
# supabase secrets set DI_GEMINI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# supabase secrets set DI_GEMINI_DEFAULT_MODEL_ADVANCED=gemini-3.1-pro-preview
# supabase secrets set DI_GEMINI_DEFAULT_MODEL_FAST=gemini-2.5-flash
# supabase secrets set DEEPSEEK_API_KEY=your_deepseek_api_key

# Decision-Intelligence LLM routing
# Prompt 1-3 -> Gemini model (3.1 Pro)
VITE_DI_GEMINI_MODEL=gemini-3.1-pro-preview

# Prompt 4-5 + chat -> DeepSeek model
# deepseek-chat (non-thinking V3.2) | deepseek-reasoner (thinking/CoT V3.2)
VITE_DI_DEEPSEEK_MODEL=deepseek-chat
VITE_DI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Comma-separated CORS allowlist for ML API
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Risk-Aware Planning (opt-in global flag)
# Set true to force risk-aware mode globally; per-run via settings.risk_mode='on'
VITE_DI_RISK_AWARE=false
