{
  "allowCustomDataForDataTypeAny": true,
  "functions": [
    {
      "id": "CLAUDE",
      "name": "CLAUDE",
      "description": "Ask Claude a question. Optionally provide cell data as context.",
      "parameters": [
        {
          "name": "prompt",
          "description": "The question or instruction for Claude",
          "type": "string",
          "dimensionality": "scalar"
        },
        {
          "name": "context",
          "description": "Optional cell data to include as context",
          "type": "string",
          "dimensionality": "scalar",
          "optional": true
        }
      ],
      "result": {
        "type": "string",
        "dimensionality": "scalar"
      },
      "options": {
        "requiresAddress": false,
        "volatile": false
      }
    },
    {
