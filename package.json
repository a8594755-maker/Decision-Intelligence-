{
  "name": "decision-intelligence",
  "private": true,
  "description": "Enterprise Digital Worker Platform for operations and analytics",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "discord-bot",
    "excel-addin"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "bot:dev": "npm run dev --workspace di-discord-bot",
    "bot:start": "npm run start --workspace di-discord-bot",
    "excel:dev": "npm run dev --workspace smartops-di-excel-addin",
    "excel:sideload": "npm run sideload --workspace smartops-di-excel-addin",
    "chatgpt-login": "node e2e/chatgpt-login.mjs",
    "chatgpt-ui-audit": "node e2e/chatgpt-ui-audit.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --reporter=verbose src/domains src/utils src/risk src/services/closed_loop",
    "test:components": "vitest run --reporter=verbose src/components src/views",
    "test:e2e:vitest": "vitest run --reporter=verbose src/test/e2e/",
    "test:dw-gate": "vitest run --reporter=verbose src/test/e2e/fullChainVerification.e2e.test.js src/test/e2e/chatToAgentLoop.e2e.test.js",
    "test:bom": "node test-bom-explosion.js",
    "test:regression": "./venv312/bin/python -m pytest -q tests/regression",
    "test:solver-regression": "./venv312/bin/python -m pytest -q tests/regression",
    "test:phase4-guardrails": "python3 -m pytest -q tests/test_action_guardrails.py tests/test_registry_router_guardrails.py tests/test_retrain_triggers.py tests/test_model_lifecycle_registry.py tests/test_promotion_gates.py",
    "lint:fix": "eslint . --fix",
    "start": "bash scripts/start.sh",
    "start:check": "bash scripts/start.sh --check",
    "healthcheck": "bash scripts/healthcheck.sh",
    "ci": "npm run lint && npm run test:run && npm run test:dw-gate && npm run test:v1-gate && npm run build",
    "test:e2e": "playwright test",
    "test:auto-debug": "node e2e/auto-crawler.js",
    "test:flows": "npx playwright test --project=flows",
    "test:flows:upload": "npx playwright test --project=flows e2e/flows/upload-workflow.spec.js",
    "test:flows:chat": "npx playwright test --project=flows e2e/flows/chat-workflow.spec.js",
    "test:flows:full": "npx playwright test --project=flows e2e/flows/full-workflow.spec.js",
    "test:flows:upload-chat": "npx playwright test --project=flows e2e/flows/chat-full-upload.spec.js",
    "test:e2e:all": "npx playwright test",
    "test:live": "node e2e/live-worker-test.js",
    "test:live:headful": "node e2e/live-worker-test.js --headful",
    "test:live:ui-only": "node e2e/live-worker-test.js --skip-llm",
    "test:live:full": "node e2e/live-worker-test.js --headful --timeout 600",
    "test:v1-gate": "npx playwright test e2e/flows/upload-to-plan.spec.js e2e/flows/revise-output.spec.js e2e/flows/approve-audit.spec.js",
    "test:v1-gate:record": "LLM_REPLAY=record npx playwright test e2e/flows/upload-to-plan.spec.js e2e/flows/revise-output.spec.js e2e/flows/approve-audit.spec.js",
    "test:v1-gate:replay": "LLM_REPLAY=replay npx playwright test e2e/flows/upload-to-plan.spec.js e2e/flows/revise-output.spec.js e2e/flows/approve-audit.spec.js",
    "test:ai-flows": "npx playwright test --project=ai-flows",
    "test:autofix": "node e2e/auto-fix-loop.mjs --source live",
    "test:autofix:dry": "node e2e/auto-fix-loop.mjs --source live --dry-run",
    "test:autofix:crawler": "node e2e/auto-fix-loop.mjs --source crawler"
  },
  "dependencies": {
    "@sentry/react": "^10.42.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tanstack/react-virtual": "^3.13.20",
    "axios": "^1.13.4",
    "date-fns": "^3.6.0",
    "fflate": "^0.8.2",
    "i18next": "^24.2.0",
    "lucide-react": "^0.555.0",
    "ralph-loop-agent": "^0.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.4.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "reactflow": "^11.11.4",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
